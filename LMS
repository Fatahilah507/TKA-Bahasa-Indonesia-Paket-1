<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aplikasi Latihan Literasi</title>
    <style>
        :root { --primary: #2c3e50; --success: #27ae60; --bg: #f5f6fa; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); padding: 20px; }
        .container { max-width: 800px; margin: auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .hidden { display: none; }
        input, select { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ccc; border-radius: 8px; box-sizing: border-box; }
        .btn { width: 100%; padding: 15px; background: var(--primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; margin-top: 10px; }
        .packet-card { border: 2px solid var(--primary); padding: 20px; margin: 10px 0; border-radius: 10px; cursor: pointer; transition: 0.3s; }
        .packet-card:hover { background: #ecf0f1; }
        .option { display: block; padding: 10px; border: 1px solid #ddd; margin: 5px 0; border-radius: 5px; cursor: pointer; }
        .option.correct { background: #d4edda; border-color: #28a745; }
        .option.wrong { background: #f8d7da; border-color: #dc3545; }
    </style>
</head>
<body>

<div class="container">
    <div id="page-login">
        <h2>Identitas Siswa</h2>
        <input type="text" id="input-nama" placeholder="Nama Lengkap" required>
        <input type="text" id="input-kelas" placeholder="Kelas" required>
        <input type="number" id="input-absen" placeholder="Nomor Absen" required>
        <button class="btn" onclick="goToMenu()">Masuk ke Menu Paket</button>
    </div>

    <div id="page-menu" class="hidden">
        <h2>Pilih Paket Latihan</h2>
        <div class="packet-card" onclick="startQuiz('A')">
            <h3>PAKET A</h3>
            <p>Materi: Kuliner Tradisional & Lingkungan</p>
        </div>
        <div class="packet-card" onclick="startQuiz('B')">
            <h3>PAKET B</h3>
            <p>Materi: Kesehatan Mental & Sastra</p>
        </div>
    </div>

    <div id="page-quiz" class="hidden">
        <h2 id="quiz-title"></h2>
        <div id="question-area"></div>
        <div id="quiz-nav" style="margin-top:20px;"></div>
    </div>

    <div id="page-result" class="hidden">
        <h2 style="text-align:center">Hasil Akhir</h2>
        <div id="score-text" style="font-size: 2em; text-align:center; font-weight:bold;"></div>
        <p id="status-upload" style="text-align:center; color: var(--success);">Mengirim data ke guru...</p>
        <button class="btn" onclick="location.reload()">Selesai & Keluar</button>
    </div>
</div>

<script>
    // MASUKKAN URL GOOGLE APP SCRIPT ANDA DI SINI
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzOo9VhCORo04jRKLuay3V-94_me67zk9PzODXBhH8E7Ms6vAF0aVSTZUrBOq51_Na5/exec";

    let currentUser = {};
    let currentPacket = "";
    let score = 0;
    let currentQuestionIndex = 0;

    // Database Soal Sederhana (Bisa Anda tambah sesuai keinginan)
    const allQuestions = {
        'A': [
            { q: "Apa tujuan jahe dimemarkan?", opt: ["Agar lunak", "Agar sari keluar", "Agar bening"], ans: 1 },
            { q: "Rasio tepung tempe kemul?", opt: ["1:1", "2:1", "3:1"], ans: 2 }
        ],
        'B': [
            { q: "Apa itu detoks digital?", opt: ["Hapus sosmed", "Istirahat gawai", "Beli HP"], ans: 1 },
            { q: "Hormon tidur adalah...", opt: ["Insulin", "Melatonin", "Kortisol"], ans: 1 }
        ]
    };

    function goToMenu() {
        currentUser.nama = document.getElementById('input-nama').value;
        currentUser.kelas = document.getElementById('input-kelas').value;
        currentUser.absen = document.getElementById('input-absen').value;

        if(!currentUser.nama) return alert("Isi nama dulu!");
        document.getElementById('page-login').classList.add('hidden');
        document.getElementById('page-menu').classList.remove('hidden');
    }

    function startQuiz(packet) {
        currentPacket = packet;
        currentQuestionIndex = 0;
        score = 0;
        document.getElementById('page-menu').classList.add('hidden');
        document.getElementById('page-quiz').classList.remove('hidden');
        document.getElementById('quiz-title').innerText = "Mengerjakan Paket " + packet;
        showQuestion();
    }

    function showQuestion() {
        const qData = allQuestions[currentPacket][currentQuestionIndex];
        let html = `<p><b>Soal ${currentQuestionIndex + 1}:</b> ${qData.q}</p>`;
        qData.opt.forEach((o, i) => {
            html += `<div class="option" onclick="handleAnswer(${i})">${o}</div>`;
        });
        document.getElementById('question-area').innerHTML = html;
    }

    function handleAnswer(selected) {
        const correct = allQuestions[currentPacket][currentQuestionIndex].ans;
        const options = document.getElementsByClassName('option');
        
        if(selected === correct) {
            options[selected].classList.add('correct');
            score += (100 / allQuestions[currentPacket].length);
        } else {
            options[selected].classList.add('wrong');
            options[correct].classList.add('correct');
        }

        setTimeout(() => {
            currentQuestionIndex++;
            if(currentQuestionIndex < allQuestions[currentPacket].length) {
                showQuestion();
            } else {
                finishQuiz();
            }
        }, 1500);
    }

    function finishQuiz() {
        document.getElementById('page-quiz').classList.add('hidden');
        document.getElementById('page-result').classList.remove('hidden');
        document.getElementById('score-text').innerText = score.toFixed(0);
        
        // KIRIM DATA KE GOOGLE SHEETS
        const formData = new URLSearchParams();
        formData.append("nama", currentUser.nama);
        formData.append("kelas", currentUser.kelas);
        formData.append("absen", currentUser.absen);
        formData.append("paket", currentPacket);
        formData.append("skor", score.toFixed(0));

        fetch(SCRIPT_URL, { method: 'POST', body: formData })
        .then(res => document.getElementById('status-upload').innerText = "Data berhasil disimpan!")
        .catch(err => document.getElementById('status-upload').innerText = "Gagal mengirim data.");
    }
</script>
</body>
</html>
